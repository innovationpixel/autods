# Vite dev server proxies /api → this Laravel URL (avoids CORS on localhost:5173).
# `php artisan serve --port=8001` from autods-backend:
VITE_API_PROXY_TARGET=http://127.0.0.1:8001

# Optional: call API directly instead of proxy (requires backend CORS for localhost:5173)
# VITE_API_URL=http://127.0.0.1:8001/api
