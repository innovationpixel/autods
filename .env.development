# Vite dev server proxies /api → this Laravel URL (avoids CORS on localhost:5173).
# Run from autods-backend: php artisan serve --port=8001
VITE_API_PROXY_TARGET=http://127.0.0.1:8001

# Do NOT set VITE_API_URL here — requests must go to /api (proxy), not the live server.
# To hit Laravel directly without proxy (needs backend CORS for localhost:5173):
# VITE_API_DIRECT_URL=http://127.0.0.1:8001/api
